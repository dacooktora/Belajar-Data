    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unused-imports": "^4.0.1",

    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",

    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.40",
