{
  "name": "data-analyst-learning",
  "version": "1.0.0",
  "description": "Platform pembelajaran Data Analyst dari nol sampai siap kerja dalam 6 bulan",
  "private": true,
  "author": "Data Analyst Learning",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/data-analyst-learning"
  },
  "homepage": "https://data-analyst-learning.vercel.app",
  "keywords": [
    "data-analyst",
    "learning",
    "education",
